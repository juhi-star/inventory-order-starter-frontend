# Frontend (Vite) — for running `npm run dev` standalone outside Docker.
# Copy to frontend/.env and adjust. Never commit frontend/.env.
# When running via `docker compose up`, the root .env file feeds the build-arg instead.

# In dev, MSW intercepts requests in the browser, so this value is rarely hit.
# When MSW is disabled (production build) the SPA talks directly to this URL.
VITE_API_BASE_URL=http://localhost:8000/api/v1
